# Dependencies
node_modules/

# Build output
dist/
dev-dist/

# Large video files — store separately (not on GitHub)
GameVideos/
*.mp4

# Accidental npm installs in asset folders — exclude all subdirs and dotfiles
BrandLogos/*/
BrandLogos/.*/
BrandLogos/.package-lock.json

# Environment variables — never commit API keys
.env
.env.local
.env.*.local

# Machine-specific bridge config overrides
bridge/config/games.local.json
bridge/.env

# Bridge runtime data
bridge/data/

# Installer binaries (large files — copy manually before compiling)
installer/herozone/
installer/vexplay/
installer/node/
installer/media/
installer/output/
installer/assets/icon.ico

# Editor
.vscode/
.idea/

# OS
.DS_Store
Thumbs.db

.vercel

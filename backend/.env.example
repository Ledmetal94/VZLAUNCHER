# ─── Supabase ───────────────────────────────────────────────
# Get these from https://supabase.com → Project Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# ─── Auth ────────────────────────────────────────────────────
# Random secret for signing JWT tokens (min 32 chars)
JWT_SECRET=change-me-to-a-long-random-string

# Super-admin secret for provisioning venues (internal use only)
SUPER_ADMIN_SECRET=change-me-super-admin-secret

# ─── Server ──────────────────────────────────────────────────
PORT=3002

# CORS: comma-separated origins allowed (no spaces)
# e.g.: https://vzlauncher.yourapp.com,http://localhost:5173
FRONTEND_URL=http://localhost:5173
